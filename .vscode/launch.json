{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug",
      "program": "${workspaceRoot}/src/main.ts",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--loader",
        "ts-node/esm"
      ]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Run",
      "program": "${workspaceRoot}/src/main.ts",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "start"
      ]
    }
  ]
}